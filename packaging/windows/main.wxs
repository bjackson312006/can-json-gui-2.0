<?xml version="1.0" encoding="windows-1252"?>
<!--
  big C generated this file

  WiX installer definition for can-json-gui-2.0 (Windows .msi).

  This replaces the default template `cargo wix init` generates. That default is
  CLI-oriented: it installs the .exe and appends its folder to PATH, but creates
  NO shortcuts, so the app never shows up in the Start Menu or on the desktop.

  This version instead:
    * installs the .exe under Program Files,
    * creates an all-users Start Menu shortcut (searchable in the Start Menu),
    * creates a Desktop shortcut,
    * uses a fixed UpgradeCode so version-to-version upgrades actually replace
      the previous install (the auto-generated template used a fresh random
      code every CI run, so upgrades never matched).

  The release workflow copies this to wix/main.wxs (where cargo-wix looks) before
  packaging. Paths below are relative to the crate root, which is cargo-wix's
  working directory when it invokes candle/light.
-->

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="can-json-gui-2.0"
        UpgradeCode="359BC0FB-2BD7-4048-9B96-A6F0937EDD59"
        Manufacturer="can-json-gui-2.0"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package
            Id="*"
            Keywords="Installer"
            Description="can-json-gui-2.0 installer"
            Manufacturer="can-json-gui-2.0"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252" />

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of can-json-gui-2.0 is already installed. Setup will now exit." />

        <MediaTemplate EmbedCab="yes" />

        <!-- Icon shown in Add/Remove Programs. The shortcuts themselves inherit
             the icon embedded in the .exe (via packaging/icon.rc), so they don't
             need an explicit Icon. -->
        <Icon Id="ProductICO" SourceFile="packaging\icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="ProductICO" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="$(var.PlatformProgramFilesFolder)">
                <Directory Id="APPLICATIONFOLDER" Name="can-json-gui-2.0">
                    <!-- The .exe lives in its own per-machine component: the file in
                         Program Files is the keypath, so this component is
                         unambiguously per-machine (no per-user data), which keeps
                         ICE57 happy. -->
                    <Component Id="binary0" Guid="*">
                        <File
                            Id="exe0"
                            Name="can-json-gui-2.0.exe"
                            Source="$(var.CargoTargetBinDir)\can-json-gui-2.0.exe"
                            KeyPath="yes" />
                    </Component>

                    <!-- Non-advertised shortcuts must live in their OWN component
                         whose keypath is an HKCU registry value, not a file. Windows
                         Installer treats shortcuts as per-user data, so:
                           * ICE43 requires the keypath to be an HKCU registry value.
                           * ICE57 forbids mixing this per-user data with the
                             per-machine .exe file in a single component.
                         Splitting them out (with the dummy HKCU keypath below) makes
                         this component purely per-user and satisfies both checks. The
                         `Directory` attribute on each Shortcut places the .lnk into
                         the Start Menu / Desktop. Target uses [#exe0]; since this
                         component and binary0 share the same Feature, there's no
                         ICE69 cross-component warning. -->
                    <Component Id="shortcuts0" Guid="*">
                        <Shortcut
                            Id="StartMenuShortcut"
                            Directory="ProgramMenuFolder"
                            Name="can-json-gui-2.0"
                            Description="can-json-gui-2.0"
                            Target="[#exe0]"
                            WorkingDirectory="APPLICATIONFOLDER" />
                        <Shortcut
                            Id="DesktopShortcut"
                            Directory="DesktopFolder"
                            Name="can-json-gui-2.0"
                            Description="can-json-gui-2.0"
                            Target="[#exe0]"
                            WorkingDirectory="APPLICATIONFOLDER" />
                        <RegistryValue
                            Root="HKCU"
                            Key="Software\can-json-gui-2.0"
                            Name="installed"
                            Type="integer"
                            Value="1"
                            KeyPath="yes" />
                    </Component>
                </Directory>
            </Directory>

            <!-- Standard shell folders the shortcuts above are placed into. In a
                 perMachine install these resolve to the all-users Start Menu and
                 Desktop, so the shortcut is searchable in the Start Menu. -->
            <Directory Id="ProgramMenuFolder" />
            <Directory Id="DesktopFolder" />
        </Directory>

        <Feature
            Id="MainApplication"
            Title="can-json-gui-2.0"
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER"
            Display="expand"
            AllowAdvertise="no"
            Absent="disallow">
            <ComponentRef Id="binary0" />
            <ComponentRef Id="shortcuts0" />
        </Feature>

        <SetProperty Id="ARPINSTALLLOCATION" Value="[APPLICATIONFOLDER]" After="CostFinalize" />

        <!-- Standard install UI with a directory chooser. -->
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />
        <UIRef Id="WixUI_InstallDir" />
        <WixVariable Id="WixUILicenseRtf" Value="packaging\windows\License.rtf" />
    </Product>
</Wix>
